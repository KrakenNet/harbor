    {
      "cve": {
        "id": "CVE-2024-1086",
        "sourceIdentifier": "cve@kernel.org",
        "published": "2024-01-31T13:15:10.067",
        "lastModified": "2024-06-25T22:15:17.853",
        "vulnStatus": "Modified",
        "descriptions": [
          {"lang": "en", "value": "A use-after-free vulnerability in the Linux kernel's netfilter: nf_tables component can be exploited to achieve local privilege escalation. The nft_verdict_init() function allows positive values as drop error within the hook verdict, and hence the nf_hook_slow() function can cause a double free vulnerability when NF_DROP is issued with a drop error which resembles NF_ACCEPT."}
        ],
        "metrics": {
          "cvssMetricV31": [
